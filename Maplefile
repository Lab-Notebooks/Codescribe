# Maplefile for CodeScribe

# Name of the base image which will
# be used to build the local image
base = "ubuntu:22.04"

# System-level dependencies for CodeScribe with HuggingFace and C++/Fortran/MPI development
build = [
    "apt-get update && apt-get install -y python3 python3-pip python3-dev python3-venv",
    "apt-get install -y build-essential gcc g++ gfortran cmake",
    "apt-get install -y openmpi-bin libopenmpi-dev",
    "apt-get install -y pandoc && apt-get clean",
]

# Name of the local image that will be
# used to pour the container and add layers
image = "codescribe"

# Name of the local container that will be used
# to run/modify the image
# Note: 'container' is a writable instance of an 'image'
container = "codescribe-container"

# Backend for service docker/singularity
backend = "docker"

# Environment variables for HuggingFace caching and model selection
environ = [
    "PATH=/tmp/venv/bin:$PATH",
    "HF_HOME=/tmp/hf",
    "CODESCRIBE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0",
    "HF_HUB_DISABLE_TELEMETRY=1",
]

# Non-sudo commands to install Python dependencies and prefetch TinyLlama model
publish = [
    "python3 -m venv /tmp/venv",
    "/tmp/venv/bin/python -m pip install --upgrade pip setuptools wheel",
    "/tmp/venv/bin/python -m pip install -r requirements/core.txt",
    "/tmp/venv/bin/python -m pip install -r requirements/transformers.txt",
    "/tmp/venv/bin/python -m pip install -r requirements/agentic.txt",
    "/tmp/venv/bin/python -m pip install -e .",
    "/tmp/venv/bin/python -m pip install -U 'huggingface_hub>=0.20'",
    "/tmp/venv/bin/huggingface-cli download TinyLlama/TinyLlama-1.1B-Chat-v1.0 --cache-dir /tmp/hf",
]
